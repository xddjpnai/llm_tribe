# ==== LLM-провайдеры (ключи видит ТОЛЬКО budget-guard; агентам не передаются) ====
ZAI_API_KEY=                # Z.ai / GLM  (glm-5.2)
DEEPSEEK_API_KEY=           # DeepSeek Platform (deepseek-v4-flash / v4-pro)
MOONSHOT_API_KEY=           # Moonshot (kimi-k2.6)
ANTHROPIC_API_KEY=          # Anthropic (claude-sonnet-5, арбитр)

# ==== Telegram (comms-bot) ====
TELEGRAM_BOT_TOKEN=         # от @BotFather
TELEGRAM_ADMIN_USER_ID=     # твой numeric user id — единственный авторизованный

# ==== Search-tool (внешний поиск с allowlist) ====
SEARCH_API_KEY=             # например, ключ Brave Search / Tavily — уточняется на шаге search-tool

# ==== Инфраструктура ====
CLICKHOUSE_PASSWORD=changeme
GRAFANA_ADMIN_PASSWORD=changeme

# ==== Бюджет (переопределяет configs/budget.yaml при необходимости) ====
# BUDGET_TOTAL_USD=500
