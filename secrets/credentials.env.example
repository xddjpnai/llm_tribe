# ЕДИНСТВЕННЫЙ файл с секретами и списком владельцев.
#
#   1. Скопируй:   cp secrets/credentials.env.example secrets/credentials.env
#   2. Заполни значения ниже (в т.ч. впиши СВОЙ Telegram id в TELEGRAM_OWNER_IDS).
#   3. Ограничь доступ:  chmod 600 secrets/credentials.env
#      (файл git-ignored и НЕ монтируется в контейнеры агентов — агенты его не видят;
#       редактируешь его только ты на VPS).
#   4. Запуск:  ./scripts/compose.sh up -d       (обёртка передаёт этот файл в compose)
#
# Изменять этот файл может только владелец ОС-пользователь VPS. Агенты не могут его
# ни прочитать, ни пропатчить (selfmod-api отклоняет любой патч к secrets/).

# ==== LLM-провайдеры (ключи видит только budget-guard) ====
ZAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=

# ==== Telegram ====
TELEGRAM_BOT_TOKEN=
# Владелец(ы) бота — numeric Telegram id через запятую. ВПИШИ СЕБЯ СЮДА.
# Владельцы имеют полный доступ (включая /kill и /user), НЕ удаляются через /user.
# Дополнительных пользователей потом добавляй командой /user (это делает владелец).
TELEGRAM_OWNER_IDS=

# ==== Search-tool ====
SEARCH_API_KEY=
SEARCH_PROVIDER=brave

# ==== Инфраструктура ====
CLICKHOUSE_PASSWORD=changeme
GRAFANA_ADMIN_PASSWORD=changeme

# ==== Бюджет (опц. переопределение configs/budget.yaml) ====
# BUDGET_TOTAL_USD=100
