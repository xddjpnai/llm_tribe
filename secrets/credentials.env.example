# ЕДИНСТВЕННЫЙ файл с секретами. Только владелец редактирует.
#   cp secrets/credentials.env.example secrets/credentials.env
#   заполнить → chmod 600 secrets/credentials.env
#   запуск: ./scripts/compose.sh up -d
# Файл git-ignored и НЕ монтируется агентам; selfmod отклоняет патчи к secrets/.

# ==== LLM-провайдеры (ключи видит только budget-guard) ====
ZAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=

# ==== Канал связи (ресурс для агента — он сам строит бота на этом токене) ====
TELEGRAM_BOT_TOKEN=
# Владелец(ы) — numeric Telegram id через запятую. ВПИШИ СЕБЯ.
TELEGRAM_OWNER_IDS=
