{
  "uid": "tribe-overview",
  "title": "llm-tribe — overview",
  "tags": [
    "llm-tribe"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "LLM spend total, $ (server accrual — in budget-guard)",
      "type": "stat",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT sum(cost_usd) AS llm_spend_usd FROM llm_traces",
          "queryType": "sql",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "title": "Tasks solved",
      "type": "stat",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT count() FROM verdicts WHERE verdict='solved'",
          "queryType": "sql",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Tasks unsolved",
      "type": "stat",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT count() FROM verdicts WHERE verdict='unsolved'",
          "queryType": "sql",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "title": "LLM spend per hour, $",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT toStartOfInterval(event_time, INTERVAL 1 HOUR) AS t, sum(cost_usd) AS cost FROM llm_traces WHERE $__timeFilter(event_time) GROUP BY t ORDER BY t",
          "queryType": "sql",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "LLM spend per agent, $/hour",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT toStartOfInterval(event_time, INTERVAL 1 HOUR) AS t, agent_id, sum(cost_usd) AS cost FROM llm_traces WHERE $__timeFilter(event_time) GROUP BY t, agent_id ORDER BY t",
          "queryType": "sql",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "Recent provider fallbacks",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT event_time, agent_id, model, round(cost_usd,5) AS cost_usd FROM llm_traces WHERE fell_back=1 ORDER BY event_time DESC LIMIT 50",
          "queryType": "sql",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Self-modification attempts",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT event_time, agent_id, action, substring(detail,1,120) AS detail FROM audit WHERE action LIKE 'selfmod%' ORDER BY event_time DESC LIMIT 50",
          "queryType": "sql",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "title": "Budget state changes (anomalies)",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT event_time, detail FROM audit WHERE action='budget_state' ORDER BY event_time DESC LIMIT 50",
          "queryType": "sql",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 9,
      "title": "Task verdicts (progress toward goals)",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "rawSql": "SELECT event_time, task_id, agent_id, verdict, round(quality,2) AS quality, substring(reason,1,120) AS reason FROM verdicts ORDER BY event_time DESC LIMIT 100",
          "queryType": "sql",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    }
  ]
}